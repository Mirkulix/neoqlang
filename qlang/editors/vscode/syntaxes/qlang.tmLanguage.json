{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "QLANG",
  "scopeName": "source.qlang",
  "patterns": [
    { "include": "#comments" },
    { "include": "#annotations" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#operations" },
    { "include": "#functions" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.qlang",
          "match": "//.*$"
        }
      ]
    },
    "annotations": {
      "patterns": [
        {
          "name": "storage.type.annotation.qlang",
          "match": "@\\w+"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.qlang",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.qlang",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.qlang",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.qlang",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.qlang",
          "match": "\\b[0-9]+\\.[0-9]+([eE][+-]?[0-9]+)?\\b"
        },
        {
          "name": "constant.numeric.integer.hex.qlang",
          "match": "\\b0[xX][0-9a-fA-F]+\\b"
        },
        {
          "name": "constant.numeric.integer.qlang",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.qlang",
          "match": "\\b(if|else|for|while|return)\\b"
        },
        {
          "name": "keyword.declaration.qlang",
          "match": "\\b(graph|node|let|fn|import|export)\\b"
        },
        {
          "name": "keyword.other.qlang",
          "match": "\\b(input|output|print)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.qlang",
          "match": "\\b(f32|f64|i32|ternary|bool)\\b"
        }
      ]
    },
    "operations": {
      "patterns": [
        {
          "name": "support.function.builtin.qlang",
          "match": "\\b(matmul|relu|sigmoid|tanh|softmax|add|mul|to_ternary|evolve|measure)\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.qlang",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.arrow.qlang",
          "match": "->"
        },
        {
          "name": "keyword.operator.assignment.qlang",
          "match": "="
        },
        {
          "name": "keyword.operator.comparison.qlang",
          "match": "(==|!=|<=|>=|<|>)"
        },
        {
          "name": "keyword.operator.arithmetic.qlang",
          "match": "(\\+|-|\\*|/|%)"
        }
      ]
    }
  }
}

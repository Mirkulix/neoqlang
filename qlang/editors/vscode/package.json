{
  "name": "qlang",
  "displayName": "QLANG",
  "description": "QLANG language support - Graph-based AI-to-AI Programming with LSP",
  "version": "0.2.0",
  "publisher": "mirkulix",
  "engines": { "vscode": "^1.80.0" },
  "categories": ["Programming Languages"],
  "activationEvents": ["onLanguage:qlang"],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [{
      "id": "qlang",
      "aliases": ["QLANG"],
      "extensions": [".qlang"],
      "configuration": "./language-configuration.json"
    }],
    "grammars": [{
      "language": "qlang",
      "scopeName": "source.qlang",
      "path": "./syntaxes/qlang.tmLanguage.json"
    }],
    "configuration": {
      "type": "object",
      "title": "QLANG",
      "properties": {
        "qlang.lsp.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable QLANG Language Server for diagnostics, completions, and hover info"
        },
        "qlang.lsp.path": {
          "type": "string",
          "default": "qlang-cli",
          "description": "Path to the qlang-cli binary (must support 'lsp' subcommand)"
        }
      }
    }
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.0"
  }
}

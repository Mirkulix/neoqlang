# IGQK SaaS Platform - Environment Variables
# Copy this file to .env and configure your values

# ==================== GENERAL ====================
ENV=production
DEBUG=false
LOG_LEVEL=INFO

# ==================== BACKEND ====================
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_WORKERS=4
BACKEND_RELOAD=false

# Database
DATABASE_URL=sqlite:///./igqk_saas.db

# API Keys (for external services)
HUGGINGFACE_TOKEN=
OPENAI_API_KEY=

# ==================== FRONTEND ====================
GRADIO_SERVER_NAME=0.0.0.0
GRADIO_SERVER_PORT=7860
GRADIO_SHARE=false

# Backend API URL (from frontend perspective)
API_BASE=http://backend:8000/api

# ==================== SECURITY ====================
SECRET_KEY=your-secret-key-here-change-in-production
ALLOWED_ORIGINS=http://localhost:7860,http://localhost:3000
CORS_ENABLED=true

# JWT Settings
JWT_SECRET_KEY=your-jwt-secret-here
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ==================== COMPRESSION ====================
# IGQK Settings
IGQK_HBAR=0.1
IGQK_GAMMA=0.01
DEFAULT_COMPRESSION_METHOD=ternary
DEFAULT_QUALITY_TARGET=0.95

# Limits
MAX_MODEL_SIZE_MB=5000
MAX_CONCURRENT_JOBS=5
JOB_TIMEOUT_MINUTES=60

# ==================== STORAGE ====================
MODELS_DIR=./compressed_models
CACHE_DIR=./models_cache
DATASETS_DIR=./datasets_cache
UPLOAD_DIR=./uploads

# ==================== MONITORING ====================
ENABLE_METRICS=true
METRICS_PORT=9090
ENABLE_LOGGING=true
LOG_FILE=./logs/igqk_saas.log

# ==================== CLOUD DEPLOYMENT (Optional) ====================
# AWS
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET=

# GCP
GCP_PROJECT_ID=
GCP_CREDENTIALS_FILE=

# Azure
AZURE_STORAGE_CONNECTION_STRING=

# ==================== EMAIL (Optional) ====================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@igqk.ai

# ==================== STRIPE (Optional) ====================
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
